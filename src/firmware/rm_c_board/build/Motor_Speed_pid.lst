  69:Core/Src/Motor_Speed_pid.c **** 
  70:Core/Src/Motor_Speed_pid.c ****     if (motor_shutdown == 1)
  71:Core/Src/Motor_Speed_pid.c ****     {
  72:Core/Src/Motor_Speed_pid.c ****         led_white_start();
  73:Core/Src/Motor_Speed_pid.c ****         Set_free();
  74:Core/Src/Motor_Speed_pid.c ****     }
  75:Core/Src/Motor_Speed_pid.c ****     else if (motor_shutdown == 0 && motor_ready == 1) 
  76:Core/Src/Motor_Speed_pid.c ****     {
  77:Core/Src/Motor_Speed_pid.c ****         set_spdL = (2 * Vcx - Wc * C) / (2 * r) * 9.55 * 19.2;
  78:Core/Src/Motor_Speed_pid.c ****         set_spdR = (2 * Vcx + Wc * C) / (2 * r) * 9.55 * 19.2;
  79:Core/Src/Motor_Speed_pid.c **** 
  80:Core/Src/Motor_Speed_pid.c ****         if (set_spdL > MAX_SPEED_RPM) set_spdL = MAX_SPEED_RPM;
