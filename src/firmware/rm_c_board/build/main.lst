 265:Core/Src/main.c **** 
 266:Core/Src/main.c **** void Serial_Output(){
 267:Core/Src/main.c ****   static uint32_t last_output_tick = 0;
 268:Core/Src/main.c ****   uint32_t now = HAL_GetTick();
 269:Core/Src/main.c ****   float dt = (now - last_output_tick) / 1000.0f;
 270:Core/Src/main.c ****   if (dt <= 0.0f || dt > 0.1f) dt = (float)SERIAL_PERIOD_MS / 1000.0f; // 首次或异常保护
 271:Core/Src/main.c ****   last_output_tick = now;
 272:Core/Src/main.c **** 
 273:Core/Src/main.c ****   const FusionQuaternion Q = FusionAhrsGetQuaternion(&ahrs);
 274:Core/Src/main.c ****   const FusionEuler euler = FusionQuaternionToEuler(Q);
 275:Core/Src/main.c ****   const FusionVector LinearAcc = FusionAhrsGetLinearAcceleration(&ahrs);
 276:Core/Src/main.c **** 
 277:Core/Src/main.c ****   // 使用全部 4 个电机计算 real_vc/real_w
 278:Core/Src/main.c ****   float avg_left_rpm  = (motor_chassis[0].speed_rpm + motor_chassis[1].speed_rpm) / 2.0f;
 279:Core/Src/main.c ****   float avg_right_rpm = ((-motor_chassis[2].speed_rpm) + (-motor_chassis[3].speed_rpm)) / 2.0f;
 280:Core/Src/main.c ****   MOTORrpm2vw(avg_left_rpm, avg_right_rpm, &real_vc, &real_w);
 281:Core/Src/main.c **** 
 282:Core/Src/main.c ****   float yaw = FusionDegreesToRadians(euler.angle.yaw), pitch = FusionDegreesToRadians(euler.angle.p
 283:Core/Src/main.c ****   float cos_yaw = cos(yaw), sin_yaw = sin(yaw);
 284:Core/Src/main.c ****   float cos_pitch = cos(pitch), sin_pitch = sin(pitch);
 285:Core/Src/main.c ****   float cos_roll = cos(roll), sin_roll = sin(roll);
 286:Core/Src/main.c ****   float delta_s = real_vc * dt;
 287:Core/Src/main.c ****   // pose integration
 288:Core/Src/main.c ****   x += (cos_yaw * sin_pitch * sin_roll - sin_yaw * cos_roll) * delta_s;
 289:Core/Src/main.c ****   y += (sin_yaw * sin_pitch * sin_roll + cos_yaw * cos_roll) * delta_s;
 290:Core/Src/main.c ****   z += (cos_pitch * sin_roll) * delta_s;
 291:Core/Src/main.c ****   
 292:Core/Src/main.c ****   // usart_printf("%d,%d,%d,%d,%d,%d,%d,%d,%d,%d,%d,%d,%d\n",	
 293:Core/Src/main.c ****   //             (int)(x * 10000), (int)(y * 10000), (int)(z * 10000), // pose
 294:Core/Src/main.c ****   //             (int)(Q.element.x * 10000), (int)(Q.element.y * 10000), (int)(Q.element.z * 10000)
 295:Core/Src/main.c ****   //             (int)(0.0f * 10000), (int)(real_vc * 10000), (int)(0.0f * 10000), // linear accele
 296:Core/Src/main.c ****   //             (int)(FusionDegreesToRadians(gyroscope.axis.x) * 10000), 
 297:Core/Src/main.c ****   //             (int)(FusionDegreesToRadians(gyroscope.axis.y) * 10000), 
 298:Core/Src/main.c ****   //             (int)(FusionDegreesToRadians(gyroscope.axis.z) * 10000));
 299:Core/Src/main.c **** 
 300:Core/Src/main.c ****     usart_printf("%f,%f,%f,%f,%f,%f,%f,%f,%f,%f,%f,%f,%f,%f,%f,%f\n",	
 301:Core/Src/main.c ****                       x, y, z, // Position coordinates
 302:Core/Src/main.c ****                       Q.element.x,
 303:Core/Src/main.c ****                       Q.element.y,
 304:Core/Src/main.c ****                       Q.element.z,
 305:Core/Src/main.c ****                       Q.element.w, // Attitude (quaternion)
 306:Core/Src/main.c ****                       0.0f, real_vc, 0.0f, // Linear velocity
 307:Core/Src/main.c ****                       FusionDegreesToRadians(gyroscope.axis.x), 
 308:Core/Src/main.c ****                       FusionDegreesToRadians(gyroscope.axis.y), 
 309:Core/Src/main.c ****                       FusionDegreesToRadians(gyroscope.axis.z), // Angular velocity
 310:Core/Src/main.c **** 
 311:Core/Src/main.c ****                       magnetometer.axis.x,
 312:Core/Src/main.c ****                       magnetometer.axis.y, 
 313:Core/Src/main.c ****                       magnetometer.axis.z); // Magnetometer data
 314:Core/Src/main.c **** 
 315:Core/Src/main.c ****   //  LongLat2XY(Convert_to_degrees(Save_Data.longitude),Convert_to_degrees(Save_Data.latitude),&gp
ARM GAS  /var/folders/w9/l2kswtfn3fs2kslkvv5vg9sh0000gn/T//ccqu7vdE.s 			page 7


