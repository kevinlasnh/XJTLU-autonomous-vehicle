  85:Core/Src/Motor_Speed_pid.c ****     }
  86:Core/Src/Motor_Speed_pid.c ****     else if (motor_shutdown == 0 && motor_ready == 0)
  87:Core/Src/Motor_Speed_pid.c ****     {
  88:Core/Src/Motor_Speed_pid.c ****         set_spdL = 0;
  89:Core/Src/Motor_Speed_pid.c ****         set_spdR = 0;
