 319:Core/Src/main.c **** //  usart_printf("%f,%f,%f,%f,%f,%f,%f,%f,%f,%f,%f,%f\n",
 320:Core/Src/main.c **** //      gyroscope.axis.x, gyroscope.axis.y, gyroscope.axis.z,
